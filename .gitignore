data/raw/
data/processed/
data/interim/
data/external/

# Common data formats
*.tsv
*.parquet
*.feather
*.arrow
*.h5
*.hdf5
*.pkl
*.pickle
*.npy
*.npz
*.json
*.jsonl
*.xml
*.db
*.sqlite
*.sqlite3
*.xls
*.xlsx

# Keep placeholder files that mark empty tracked folders
!.gitkeep


